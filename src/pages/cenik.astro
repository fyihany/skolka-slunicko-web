---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from 'astro-icon/components';
import PageHero from "../components/PageHero.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Domů", "item": "https://www.skolka-slunicko.cz" },
      { "@type": "ListItem", "position": 2, "name": "Ceník", "item": "https://www.skolka-slunicko.cz/cenik" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Jak se platí školné?",
        "acceptedAnswer": { "@type": "Answer", "text": "Školné se platí bankovním převodem. Platební informace obdržíte po přijetí dítěte." }
      },
      {
        "@type": "Question",
        "name": "Kdy musím zaplatit první školné?",
        "acceptedAnswer": { "@type": "Answer", "text": "První školné je splatné 3 pracovní dny před nástupem dítěte do školky." }
      },
      {
        "@type": "Question",
        "name": "Co je zahrnuto ve stravném?",
        "acceptedAnswer": { "@type": "Answer", "text": "Ve stravném jsou zahrnuty svačiny (1–2 dle délky pobytu), oběd a pitný režim po celý den." }
      }
    ]
  }
];
---

<BaseLayout
  title="Ceník školného | Mateřská škola Sluníčko Ostrava-Poruba"
  description="Ceník soukromé mateřské školy Sluníčko v Ostravě-Porubě. Pravidelná i nepravidelná docházka pro děti od 2 let. Od 2 750 Kč/měsíc."
  schema={schema}
  canonical="https://www.skolka-slunicko.cz/cenik"
>

  <!-- Breadcrumb -->
  <nav aria-label="Drobečková navigace" class="bg-white border-b border-gray-100">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center gap-2 text-sm text-gray-500">
        <li><a href="/" class="hover:text-[#D4A017] transition">Domů</a></li>
        <li aria-hidden="true" class="text-gray-300">/</li>
        <li class="font-semibold text-[#2D2D2D]" aria-current="page">Ceník</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <PageHero labelId="cenik-heading" icon="ph:tag-duotone">
    <h1 id="cenik-heading" class="text-4xl font-black text-[#2D2D2D] sm:text-5xl leading-tight">
      Ceník školného
    </h1>
    <p class="mt-4 text-lg text-gray-600 leading-relaxed">
      Nabízíme flexibilní docházku přizpůsobenou vašemu tempu — od nepravidelné výpomoci až po celodenní péči.
    </p>
    <p class="mt-2 text-sm text-gray-500">
      Provozní doba: <strong class="text-[#2D2D2D]">Po–Pá 6:30–17:00</strong> · Děti od 2 let
    </p>
  </PageHero>

  <!-- Tři hlavní typy docházky -->
  <section class="py-14 bg-white" aria-labelledby="typy-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 id="typy-heading" class="text-2xl font-black text-[#2D2D2D] mb-2 text-center">Typy docházky</h2>
      <p class="text-gray-500 text-center mb-10">Vyberte si variantu, která vám nejlépe vyhovuje.</p>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">

        <!-- Nepravidelná -->
        <div class="rounded-xl bg-[#E3F2FD] ring-1 ring-[#90CAF9]/40 p-7 flex flex-col">
          <div class="mb-4">
            <Icon name="ph:calendar-dots-duotone" class="h-9 w-9 text-[#1565C0]" />
          </div>
          <h3 class="text-lg font-black text-[#2D2D2D] mb-1">Nepravidelná docházka</h3>
          <p class="text-sm text-gray-600 mb-5 leading-relaxed">Ideální pro rodiny s proměnlivým režimem. Dopředu sjednáte počet dní.</p>
          <div class="mt-auto space-y-2">
            <div class="flex justify-between items-center text-sm">
              <span class="text-gray-600">5 dní / měsíc</span>
              <span class="font-black text-[#1565C0]">od 2 450 Kč</span>
            </div>
            <div class="flex justify-between items-center text-sm">
              <span class="text-gray-600">10 dní / měsíc</span>
              <span class="font-black text-[#1565C0]">od 3 550 Kč</span>
            </div>
            <div class="flex justify-between items-center text-sm border-t border-[#90CAF9]/30 pt-2">
              <span class="text-gray-500 text-xs">děti do 3 let (dopoledne)</span>
              <span class="font-bold text-[#1565C0] text-xs">3 450 Kč</span>
            </div>
          </div>
        </div>

        <!-- Pravidelná do 6 měs -->
        <div class="rounded-xl bg-[#E8F5E9] ring-1 ring-[#A5D6A7]/40 p-7 flex flex-col">
          <div class="mb-4">
            <Icon name="ph:calendar-check-duotone" class="h-9 w-9 text-[#2E7D32]" />
          </div>
          <h3 class="text-lg font-black text-[#2D2D2D] mb-1">Pravidelná <span class="text-[#2E7D32]">do 6 měsíců</span></h3>
          <p class="text-sm text-gray-600 mb-5 leading-relaxed">Stabilní docházka na kratší závazek. K dispozici celý i půl den.</p>
          <div class="mt-auto space-y-2">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Děti 3+ let</p>
            <div class="flex justify-between items-center text-sm">
              <span class="text-gray-600">Celý den</span>
              <span class="font-black text-[#2E7D32]">4 650 Kč/měs</span>
            </div>
            <div class="flex justify-between items-center text-sm">
              <span class="text-gray-600">Půl den</span>
              <span class="font-black text-[#2E7D32]">3 950 Kč/měs</span>
            </div>
            <div class="border-t border-[#A5D6A7]/30 pt-2">
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Děti do 3 let</p>
              <div class="flex justify-between items-center text-sm">
                <span class="text-gray-600">Celý den</span>
                <span class="font-bold text-[#2E7D32]">5 650 Kč/měs</span>
              </div>
              <div class="flex justify-between items-center text-sm">
                <span class="text-gray-600">Půl den</span>
                <span class="font-bold text-[#2E7D32]">4 650 Kč/měs</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Pravidelná 6+ měs – doporučená -->
        <div class="rounded-xl bg-[#FFF9C4] ring-2 ring-[#FFD600]/60 p-7 flex flex-col relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="rounded-lg bg-[#F9C22E] px-4 py-1 text-xs font-black text-[#2D2D2D] shadow-sm">
              Nejlepší cena
            </span>
          </div>
          <div class="mb-4">
            <Icon name="ph:star-duotone" class="h-9 w-9 text-[#D4A017]" />
          </div>
          <h3 class="text-lg font-black text-[#2D2D2D] mb-1">Pravidelná <span class="text-[#D4A017]">6+ měsíců</span></h3>
          <p class="text-sm text-gray-600 mb-5 leading-relaxed">Nejvýhodnější sazba pro celoroční docházku. Pouze celý den.</p>
          <div class="mt-auto space-y-2">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Děti 3+ let</p>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600">Celý den</span>
              <span class="text-xl font-black text-[#D4A017]">3 500 Kč/měs</span>
            </div>
            <div class="border-t border-[#FFD600]/30 pt-2">
              <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Děti do 3 let</p>
              <div class="flex justify-between items-center">
                <span class="text-sm text-gray-600">Celý den</span>
                <span class="text-xl font-black text-[#D4A017]">4 000 Kč/měs</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Strava + Podmínky -->
  <section class="py-14 bg-[#FFFBF0]" aria-labelledby="strava-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">

        <!-- Strava -->
        <div>
          <div class="flex items-center gap-3 mb-6">
            <Icon name="ph:fork-knife-duotone" class="h-7 w-7 text-[#D4A017]" />
            <h2 id="strava-heading" class="text-xl font-black text-[#2D2D2D]">Strava</h2>
          </div>
          <p class="text-sm text-gray-600 mb-5 leading-relaxed">
            Platba přes systém <strong>Strava.cz</strong>. Přihlašovací údaje obdržíte po přijetí dítěte.
          </p>
          <div class="space-y-3">
            <div class="rounded-lg bg-white p-4 ring-1 ring-[#F9C22E]/30 flex justify-between items-center">
              <div>
                <p class="font-bold text-sm text-[#2D2D2D]">Celý den</p>
                <p class="text-xs text-gray-500">2× svačina + oběd + pitný režim</p>
              </div>
              <span class="text-lg font-black text-[#D4A017] shrink-0">75 Kč / den</span>
            </div>
            <div class="rounded-lg bg-white p-4 ring-1 ring-[#F9C22E]/30 flex justify-between items-center">
              <div>
                <p class="font-bold text-sm text-[#2D2D2D]">Půl den</p>
                <p class="text-xs text-gray-500">1× svačina + oběd + pitný režim</p>
              </div>
              <span class="text-lg font-black text-[#D4A017] shrink-0">65 Kč / den</span>
            </div>
          </div>
        </div>

        <!-- Platební podmínky -->
        <div>
          <div class="flex items-center gap-3 mb-6">
            <Icon name="ph:bank-duotone" class="h-7 w-7 text-[#D4A017]" />
            <h2 class="text-xl font-black text-[#2D2D2D]">Platební podmínky</h2>
          </div>
          <ul class="space-y-4">
            {[
              {
                n: "1",
                title: "Způsob platby",
                text: "Bankovní převod na základě zaslaných platebních informací.",
              },
              {
                n: "2",
                title: "První platba",
                text: "Splatná 3 pracovní dny před nástupem dítěte.",
              },
              {
                n: "3",
                title: "Další měsíce",
                text: "Vždy do 20. dne předchozího měsíce.",
              },
            ].map(({ n, title, text }) => (
              <li class="flex gap-4 items-start">
                <span class="shrink-0 h-7 w-7 rounded-full bg-[#F9C22E] flex items-center justify-center text-xs font-black text-[#2D2D2D]">{n}</span>
                <div>
                  <p class="font-bold text-sm text-[#2D2D2D]">{title}</p>
                  <p class="text-sm text-gray-600 mt-0.5">{text}</p>
                </div>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-14 bg-[#F5F0FF]" aria-labelledby="faq-heading">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8">
      <h2 id="faq-heading" class="text-xl font-black text-[#2D2D2D] mb-6 text-center">Časté dotazy k platbám</h2>
      <div class="space-y-3">
        {[
          {
            q: "Jak se platí školné?",
            a: "Školné se platí bankovním převodem. Platební informace obdržíte po přijetí dítěte do školky.",
          },
          {
            q: "Kdy musím zaplatit první školné?",
            a: "První školné je splatné 3 pracovní dny před nástupem dítěte. Prosíme o dodržení termínu.",
          },
          {
            q: "Co je zahrnuto ve stravném?",
            a: "Ve stravném jsou zahrnuty svačiny (1–2 dle délky pobytu), oběd a pitný režim po celý den. Platba přes systém Strava.cz.",
          },
        ].map(({ q, a }) => (
          <details class="rounded-lg bg-white ring-1 ring-[#CE93D8]/40 open:ring-[#F9C22E] transition group">
            <summary class="flex items-center justify-between px-5 py-4 font-bold text-sm text-[#2D2D2D] cursor-pointer list-none">
              <span>{q}</span>
              <svg class="h-4 w-4 shrink-0 text-[#D4A017] transition group-open:rotate-180 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-5 pb-4 text-sm text-gray-600 leading-relaxed">{a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-14 bg-[#2D2D2D]" aria-labelledby="cenik-cta-heading">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 id="cenik-cta-heading" class="text-2xl font-black text-white">Připraveni zapsat dítě?</h2>
      <p class="mt-3 text-gray-400">Kontaktujte nás a domluvíme všechny detaily.</p>
      <div class="mt-7 flex flex-wrap justify-center gap-4">
        <a href="/registrace" class="inline-flex items-center rounded-lg bg-[#F9C22E] px-7 py-3.5 font-bold text-[#2D2D2D] transition hover:bg-[#D4A017]">
          Zapsat dítě
        </a>
        <a href="/kontakt" class="inline-flex items-center rounded-lg border-2 border-white px-7 py-3.5 font-bold text-white transition hover:bg-white hover:text-[#2D2D2D]">
          Kontakt
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
