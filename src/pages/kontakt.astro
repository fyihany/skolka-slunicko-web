---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Domů", "item": "https://www.skolka-slunicko.cz" },
      { "@type": "ListItem", "position": 2, "name": "Kontakt", "item": "https://www.skolka-slunicko.cz/kontakt" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Soukromá mateřská škola Sluníčko",
    "url": "https://www.skolka-slunicko.cz",
    "telephone": "+420725828130",
    "email": "info@skolka-slunicko.cz",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Bohuslava Martinů 812/11",
      "addressLocality": "Ostrava-Poruba",
      "postalCode": "708 00",
      "addressCountry": "CZ"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 49.8256,
      "longitude": 18.1525
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "06:30",
        "closes": "17:00"
      }
    ],
    "sameAs": [
      "https://www.facebook.com/materskaskolkaslunicko",
      "https://www.instagram.com/materska_skola_slunicko"
    ]
  }
];
---

<BaseLayout
  title="Kontakt | Mateřská škola Sluníčko Ostrava-Poruba"
  description="Kontaktní informace MŠ Sluníčko Ostrava-Poruba. Telefon: 725 828 130. Email: info@skolka-slunicko.cz. Adresa: Bohuslava Martinů 812/11, Ostrava-Poruba."
  schema={schema}
  canonical="https://www.skolka-slunicko.cz/kontakt"
>

  <!-- Breadcrumb -->
  <nav aria-label="Drobečková navigace" class="bg-white border-b border-gray-100">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center gap-2 text-sm text-gray-500">
        <li><a href="/" class="hover:text-[#D4A017] transition">Domů</a></li>
        <li aria-hidden="true" class="text-gray-300">/</li>
        <li class="font-semibold text-[#2D2D2D]" aria-current="page">Kontakt</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <PageHero labelId="kontakt-heading" icon="ph:envelope-duotone">
    <h1 id="kontakt-heading" class="text-4xl font-black text-[#2D2D2D] sm:text-5xl leading-tight">
      Kontakt
    </h1>
    <p class="mt-4 text-lg text-gray-600 leading-relaxed">
      Rádi odpovíme na vaše dotazy a ukážeme vám školku osobně.
    </p>
  </PageHero>

  <!-- Kontakt grid -->
  <section class="py-16 bg-[#FFF0F5]" aria-labelledby="kontakt-info-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 id="kontakt-info-heading" class="sr-only">Kontaktní informace a mapa</h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

        <!-- Kontaktní informace -->
        <div>
          <div class="rounded-xl bg-[#FFF0F5] p-8 ring-1 ring-[#F48FB1]/30 space-y-6">

            <div class="flex gap-4 items-start">
              <div class="flex-shrink-0 h-10 w-10 rounded-lg bg-[#FF9800]/15 flex items-center justify-center" aria-hidden="true">
                <svg class="h-5 w-5 text-[#FF9800]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-bold uppercase tracking-wide text-gray-400 mb-0.5">Adresa</p>
                <address class="not-italic font-semibold text-[#2D2D2D] text-sm leading-relaxed">
                  Bohuslava Martinů 812/11<br />
                  Ostrava-Poruba, 708 00
                </address>
              </div>
            </div>

            <div class="flex gap-4 items-start">
              <div class="flex-shrink-0 h-10 w-10 rounded-lg bg-[#4CAF50]/15 flex items-center justify-center" aria-hidden="true">
                <svg class="h-5 w-5 text-[#4CAF50]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-bold uppercase tracking-wide text-gray-400 mb-0.5">Telefon</p>
                <a href="tel:+420725828130" class="font-bold text-[#2D2D2D] hover:text-[#D4A017] transition text-sm">
                  725 828 130
                </a>
              </div>
            </div>

            <div class="flex gap-4 items-start">
              <div class="flex-shrink-0 h-10 w-10 rounded-lg bg-[#2196F3]/15 flex items-center justify-center" aria-hidden="true">
                <svg class="h-5 w-5 text-[#2196F3]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-bold uppercase tracking-wide text-gray-400 mb-0.5">E-mail</p>
                <a href="mailto:info@skolka-slunicko.cz" class="font-bold text-[#2D2D2D] hover:text-[#D4A017] transition text-sm">
                  info@skolka-slunicko.cz
                </a>
              </div>
            </div>

            <div class="flex gap-4 items-start">
              <div class="flex-shrink-0 h-10 w-10 rounded-lg bg-[#9C27B0]/15 flex items-center justify-center" aria-hidden="true">
                <svg class="h-5 w-5 text-[#9C27B0]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-bold uppercase tracking-wide text-gray-400 mb-0.5">Provozní doba</p>
                <p class="font-semibold text-[#2D2D2D] text-sm">Pondělí–pátek 6:30–17:00</p>
              </div>
            </div>

            <!-- Sociální sítě -->
            <div class="border-t border-[#F9C22E]/30 pt-5">
              <p class="text-xs font-bold uppercase tracking-wide text-gray-400 mb-3">Sledujte nás</p>
              <div class="flex gap-3">
                <a
                  href="https://www.facebook.com/materskaskolkaslunicko"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2 rounded-lg bg-[#1877F2]/10 px-4 py-2 text-sm font-bold text-[#1877F2] hover:bg-[#1877F2]/20 transition"
                  aria-label="Facebook MŠ Sluníčko"
                >
                  <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                  </svg>
                  Facebook
                </a>
                <a
                  href="https://www.instagram.com/materska_skola_slunicko"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2 rounded-lg bg-[#E1306C]/10 px-4 py-2 text-sm font-bold text-[#E1306C] hover:bg-[#E1306C]/20 transition"
                  aria-label="Instagram MŠ Sluníčko"
                >
                  <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                  </svg>
                  Instagram
                </a>
              </div>
            </div>
          </div>

          <!-- Rychlý kontakt -->
          <div class="mt-6 grid grid-cols-2 gap-3">
            <a
              href="tel:+420725828130"
              class="flex items-center justify-center gap-2 rounded-lg bg-[#F9C22E] px-4 py-3 font-bold text-sm text-[#2D2D2D] transition hover:bg-[#D4A017]"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              Zavolat
            </a>
            <a
              href="/registrace"
              class="flex items-center justify-center gap-2 rounded-lg border-2 border-[#2D2D2D] px-4 py-3 font-bold text-sm text-[#2D2D2D] transition hover:bg-[#2D2D2D] hover:text-white"
            >
              Zapsat dítě
            </a>
          </div>
        </div>

        <!-- Google Maps -->
        <div>
          <div class="rounded-xl overflow-hidden ring-1 ring-[#F9C22E]/30">
            <iframe
              title="Mapa MŠ Sluníčko"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2573.8!2d18.1525!3d49.8256!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sMateřská+škola+Sluníčko!5e0!3m2!1scs!2scz!4v1"
              width="100%"
              height="350"
              style="border:0;"
              loading="lazy"
              allowfullscreen
              referrerpolicy="no-referrer-when-downgrade"
              aria-label="Mapa s umístěním MŠ Sluníčko v Ostravě-Porubě"
            ></iframe>
          </div>
          <p class="mt-4 text-sm text-gray-500 text-center">
            Bohuslava Martinů 812/11, Ostrava-Poruba 708 00
          </p>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
