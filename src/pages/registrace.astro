---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from 'astro-icon/components';
import PageHero from "../components/PageHero.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Domů", "item": "https://www.skolka-slunicko.cz" },
      { "@type": "ListItem", "position": 2, "name": "Registrace", "item": "https://www.skolka-slunicko.cz/registrace" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Od kolika let přijímáte děti?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Přijímáme děti od 2 let. Podmínkou je zvládnutá základní hygiena."
        }
      },
      {
        "@type": "Question",
        "name": "Musí být dítě bez plínek?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ano, dítě musí být bez plínek. Výjimkou je čas odpočinku (spaní), kde je povolena nepromokavá podložka."
        }
      },
      {
        "@type": "Question",
        "name": "Jak dlouho trvá přijímací proces?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Přijímáme děti průběžně po celý školní rok. Délka procesu záleží na aktuální kapacitě školky."
        }
      }
    ]
  }
];
---

<BaseLayout
  title="Registrace a přijetí | Mateřská škola Sluníčko Ostrava-Poruba"
  description="Jak zapsat dítě do MŠ Sluníčko v Ostravě-Porubě. Přijímáme děti od 2 let průběžně po celý rok. Podmínky přijetí, formulář a potřebné dokumenty."
  schema={schema}
  canonical="https://www.skolka-slunicko.cz/registrace"
>

  <!-- Breadcrumb -->
  <nav aria-label="Drobečková navigace" class="bg-white border-b border-gray-100">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center gap-2 text-sm text-gray-500">
        <li><a href="/" class="hover:text-[#D4A017] transition">Domů</a></li>
        <li aria-hidden="true" class="text-gray-300">/</li>
        <li class="font-semibold text-[#2D2D2D]" aria-current="page">Registrace</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <PageHero labelId="registrace-heading" icon="ph:clipboard-text-duotone">
    <h1 id="registrace-heading" class="text-4xl font-black text-[#2D2D2D] sm:text-5xl leading-tight">
      Registrace a přijetí
    </h1>
    <p class="mt-4 text-lg text-gray-600 leading-relaxed">
      Přijímáme děti průběžně po celý školní rok. Přijďte se kdykoli podívat.
    </p>
  </PageHero>

  <!-- Jak to probíhá -->
  <section class="py-16 bg-white" aria-labelledby="jak-to-probiha-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 id="jak-to-probiha-heading" class="text-3xl font-black text-[#2D2D2D] md:text-4xl">Jak to probíhá?</h2>
        <p class="mt-3 text-gray-500">Čtyři jednoduché kroky k zápisu vašeho dítěte.</p>
      </div>
      <div class="max-w-3xl mx-auto">
        <ol class="space-y-6">
          {[
            {
              step: "1",
              icon: "ph:phone-duotone",
              title: "Zavolejte nebo napište",
              desc: "Kontaktujte nás a domluvíme si prohlídku školky. Rádi vám ukážeme prostory a zodpovíme veškeré dotazy.",
              bg: "bg-[#FFF9C4]", ring: "ring-[#FFD600]/40",
            },
            {
              step: "2",
              icon: "ph:file-doc-duotone",
              title: "Vyplňte přihlášku",
              desc: "Stáhněte přihlášku z naší stránky ke stažení. Nechte ji potvrdit u vašeho pediatra.",
              bg: "bg-[#E3F2FD]", ring: "ring-[#90CAF9]/40",
            },
            {
              step: "3",
              icon: "ph:clipboard-text-duotone",
              title: "Přineste dokumenty",
              desc: "Doneste vyplněnou a potvrzenou přihlášku spolu se zdravotním potvrzením od lékaře.",
              bg: "bg-[#E8F5E9]", ring: "ring-[#A5D6A7]/40",
            },
            {
              step: "4",
              icon: "ph:check-circle-duotone",
              title: "Vaše dítě nastoupí",
              desc: "Po splnění všech podmínek a zaplacení školného je vaše dítě přijato a může nastoupit.",
              bg: "bg-[#FCE4EC]", ring: "ring-[#F48FB1]/40",
            },
          ].map(({ step, icon, title, desc, bg, ring }) => (
            <li class="flex gap-5 items-start">
              <span class="flex-shrink-0 h-10 w-10 rounded-full bg-[#F9C22E] flex items-center justify-center text-lg font-black text-[#2D2D2D]">
                {step}
              </span>
              <div class:list={["rounded-lg flex-1 p-5 ring-1", bg, ring]}>
                <h3 class="font-bold text-[#2D2D2D]">{title}</h3>
                <p class="text-sm text-gray-600 mt-1 leading-relaxed">{desc}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- Podmínky přijetí -->
  <section class="py-14 bg-[#FFFBF0]" aria-labelledby="podminky-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center">
        <h2 id="podminky-heading" class="text-2xl font-black text-[#2D2D2D] mb-6">Podmínky přijetí</h2>
        <ul class="space-y-3 text-left">
          {[
            "Splněné požadavky přihlášky (vyplněná a lékařem potvrzená přihláška).",
            "Dítě je bez plínek (mladší děti mohou mít nepromokavou podložku při spaní).",
            "Řádně zaplacené školné před nástupem.",
          ].map((item) => (
            <li class="flex gap-3 items-start bg-white rounded-lg p-4 ring-1 ring-[#F9C22E]/30">
              <span class="flex-shrink-0 mt-0.5 h-5 w-5 rounded-full bg-[#F9C22E] flex items-center justify-center" aria-hidden="true">
                <svg class="h-3 w-3 text-[#2D2D2D]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </span>
              <span class="text-sm text-gray-700 leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>
        <p class="mt-6 text-sm text-gray-500">
          Ke stažení potřebných dokumentů přejděte na{" "}
          <a href="/ke-stazeni" class="font-semibold text-[#D4A017] hover:underline">stránku ke stažení</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- Formulář -->
  <section class="py-16 bg-[#FFFBF0]" aria-labelledby="formular-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 id="formular-heading" class="text-3xl font-black text-[#2D2D2D] md:text-4xl mb-4">
            Mám zájem
          </h2>
          <p class="text-gray-600 leading-relaxed mb-6">
            Vyplňte formulář a ozveme se vám co nejdříve s informacemi o volné kapacitě a dalším postupu.
          </p>
          <div class="rounded-xl bg-[#FFFBF0] p-6 ring-1 ring-[#F9C22E]/30">
            <p class="text-sm font-semibold text-[#2D2D2D] mb-3">Nebo nás kontaktujte přímo:</p>
            <div class="space-y-2">
              <a href="tel:+420725828130" class="flex items-center gap-2 text-sm font-bold text-[#D4A017] hover:underline">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                725 828 130
              </a>
              <a href="mailto:info@skolka-slunicko.cz" class="flex items-center gap-2 text-sm font-bold text-[#D4A017] hover:underline">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                info@skolka-slunicko.cz
              </a>
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-[#FFFBF0] p-8 ring-1 ring-[#F9C22E]/30">
          <form
            method="POST"
            action="#contact-sent"
            data-form="registrace"
            id="registrace-form"
            novalidate
          >
            <div class="space-y-4">
              <div>
                <label for="jmeno-rodice" class="block text-sm font-bold text-[#2D2D2D] mb-1">
                  Jméno rodiče <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="jmeno-rodice"
                  name="jmeno_rodice"
                  required
                  autocomplete="name"
                  class="w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm text-[#2D2D2D] placeholder-gray-400 focus:border-[#F9C22E] focus:outline-none focus:ring-2 focus:ring-[#F9C22E]/30 transition"
                  placeholder="Jana Nováková"
                />
              </div>
              <div>
                <label for="telefon" class="block text-sm font-bold text-[#2D2D2D] mb-1">
                  Telefon <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <input
                  type="tel"
                  id="telefon"
                  name="telefon"
                  required
                  autocomplete="tel"
                  class="w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm text-[#2D2D2D] placeholder-gray-400 focus:border-[#F9C22E] focus:outline-none focus:ring-2 focus:ring-[#F9C22E]/30 transition"
                  placeholder="+420 777 123 456"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-bold text-[#2D2D2D] mb-1">
                  E-mail <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  autocomplete="email"
                  class="w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm text-[#2D2D2D] placeholder-gray-400 focus:border-[#F9C22E] focus:outline-none focus:ring-2 focus:ring-[#F9C22E]/30 transition"
                  placeholder="jana@email.cz"
                />
              </div>
              <div>
                <label for="dite" class="block text-sm font-bold text-[#2D2D2D] mb-1">
                  Jméno a věk dítěte <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <input
                  type="text"
                  id="dite"
                  name="dite"
                  required
                  class="w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm text-[#2D2D2D] placeholder-gray-400 focus:border-[#F9C22E] focus:outline-none focus:ring-2 focus:ring-[#F9C22E]/30 transition"
                  placeholder="Tomáš, 3 roky"
                />
              </div>
              <div>
                <label for="zprava" class="block text-sm font-bold text-[#2D2D2D] mb-1">
                  Zpráva <span class="text-gray-400 font-normal">(nepovinné)</span>
                </label>
                <textarea
                  id="zprava"
                  name="zprava"
                  rows="3"
                  class="w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm text-[#2D2D2D] placeholder-gray-400 focus:border-[#F9C22E] focus:outline-none focus:ring-2 focus:ring-[#F9C22E]/30 transition resize-none"
                  placeholder="Vaše otázky nebo poznámky..."
                ></textarea>
              </div>
              <button
                type="submit"
                class="w-full rounded-lg bg-[#F9C22E] px-6 py-3.5 font-bold text-[#2D2D2D] transition hover:bg-[#D4A017] shadow-md shadow-[#F9C22E]/20"
              >
                Odeslat zájem
              </button>
            </div>

            <div id="form-success" class="hidden mt-4 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm font-semibold text-green-800" role="alert" aria-live="polite">
              Děkujeme! Ozveme se vám co nejdříve.
            </div>
          </form>

          <p class="mt-4 text-xs text-gray-400 leading-relaxed">
            <em>Formulář je připraven pro budoucí propojení s Google Apps Script.</em>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-[#F5F0FF]" aria-labelledby="faq-registrace-heading">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 id="faq-registrace-heading" class="text-2xl font-black text-[#2D2D2D] mb-8 text-center">Časté dotazy</h2>
      <div class="space-y-4">
        {[
          {
            q: "Od kolika let přijímáte děti?",
            a: "Přijímáme děti od 2 let. Podmínkou přijetí je zvládnutá základní hygiena.",
          },
          {
            q: "Musí být dítě bez plínek?",
            a: "Ano, dítě by mělo být bez plínek. Výjimkou je čas odpočinku (spaní), kde je povolena nepromokavá podložka.",
          },
          {
            q: "Jak dlouho trvá přijímací proces?",
            a: "Přijímáme děti průběžně po celý školní rok. Délka přijímacího procesu záleží na aktuální kapacitě školky.",
          },
        ].map(({ q, a }) => (
          <details class="rounded-lg bg-white ring-1 ring-[#F9C22E]/30 open:ring-[#F9C22E] transition group">
            <summary class="flex items-center justify-between px-6 py-4 font-bold text-[#2D2D2D] cursor-pointer list-none">
              <span>{q}</span>
              <svg class="h-5 w-5 text-[#D4A017] transition group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-5 text-sm text-gray-600 leading-relaxed">{a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  const form = document.getElementById('registrace-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('form-success');

  if (form && successMsg) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      // TODO: Odeslat data přes Google Apps Script API
      // const data = new FormData(form);
      // fetch('APPS_SCRIPT_URL', { method: 'POST', body: data });
      successMsg.classList.remove('hidden');
      form.reset();
    });
  }
</script>
