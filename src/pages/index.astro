---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from 'astro-icon/components';
import Logo from "../components/Logo.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": ["ChildCare", "LocalBusiness"],
    "name": "Soukromá mateřská škola Sluníčko",
    "alternateName": "MŠ Sluníčko",
    "description": "Soukromá mateřská škola rodinného typu v Ostravě-Porubě. Individuální přístup, tvořivost a láska k dětem od 2 do 6 let.",
    "url": "https://www.skolka-slunicko.cz",
    "logo": "https://www.skolka-slunicko.cz/logo.svg",
    "image": "https://www.skolka-slunicko.cz/logo.svg",
    "telephone": "+420725828130",
    "email": "info@skolka-slunicko.cz",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Bohuslava Martinů 812/11",
      "addressLocality": "Ostrava-Poruba",
      "postalCode": "708 00",
      "addressCountry": "CZ"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 49.8256,
      "longitude": 18.1525
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "06:30",
        "closes": "17:00"
      }
    ],
    "priceRange": "3 500–5 650 Kč/měsíc",
    "sameAs": [
      "https://www.facebook.com/materskaskolkaslunicko",
      "https://www.instagram.com/materska_skola_slunicko"
    ]
  }
];
---

<BaseLayout
  title="Mateřská škola Sluníčko Ostrava-Poruba | Soukromá školka rodinného typu"
  description="Soukromá mateřská škola v Ostravě-Porubě pro děti od 2 do 6 let. Individuální přístup, bruslení, muzikoterapie, keramika. Otevřeno Po–Pá 6:30–17:00."
  schema={schema}
>

  <!-- Hero -->
  <section class="relative overflow-hidden bg-[#FFFBF0] py-16 md:py-24">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute -top-16 -right-16 h-64 w-64 rounded-full bg-[#F9C22E]/20"></div>
      <div class="absolute bottom-0 -left-10 h-48 w-48 rounded-full bg-[#F9C22E]/15"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:items-center">
        <div data-hero-content>
          <p class="mb-3 inline-flex items-center rounded-lg bg-[#F9C22E]/30 px-4 py-1 text-sm font-semibold text-[#D4A017]">
            Školka rodinného typu · Ostrava-Poruba
          </p>
          <h1 class="text-4xl font-black leading-tight text-[#2D2D2D] sm:text-5xl md:text-6xl">
            Fantazie.<br/>
            <span class="text-[#D4A017]">Tvořivost.</span><br/>
            Sebevědomí.
          </h1>
          <p class="mt-6 text-lg text-gray-600 max-w-lg leading-relaxed hero-desc">
            V naší rodinné školce přistupujeme ke každému dítěti s láskou a péčí, které potřebuje pro zdravý rozvoj osobnosti. Kapacita 24 dětí znamená, že vždy víme, jak se vaše dítě má.
          </p>
          <div class="mt-8 flex flex-wrap gap-4 hero-btns">
            <a href="/registrace" class="inline-flex items-center justify-center rounded-lg bg-[#F9C22E] px-7 py-3.5 font-bold text-[#2D2D2D] transition hover:bg-[#D4A017] shadow-lg shadow-[#F9C22E]/30">
              Zapsat dítě
            </a>
            <a href="/o-skolce" class="inline-flex items-center justify-center rounded-lg border-2 border-[#2D2D2D] px-7 py-3.5 font-bold text-[#2D2D2D] transition hover:bg-[#2D2D2D] hover:text-white">
              Více o školce
            </a>
          </div>
          <div class="mt-10 flex flex-wrap gap-6 hero-badges">
            {[
              { icon: "ph:clock-duotone", text: "Po–Pá 6:30–17:00" },
              { icon: "ph:baby-duotone", text: "Děti od 2 let" },
              { icon: "ph:house-simple-duotone", text: "Max. 24 dětí" },
            ].map(({ icon, text }) => (
              <div class="flex items-center gap-2 text-sm font-semibold text-gray-600">
                <Icon name={icon} class="h-5 w-5 text-[#D4A017]" aria-hidden="true" />
                <span>{text}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="flex justify-center" data-hero-logo>
          <div class="relative">
            <div class="absolute inset-0 rotate-3 rounded-xl bg-[#F9C22E]/40 scale-110"></div>
            <img
              src="/logo.svg"
              alt="Logo Mateřské školy Sluníčko"
              width="320"
              height="320"
              class="relative h-64 w-64 md:h-80 md:w-80 drop-shadow-xl"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Hodnoty -->
  <section class="py-16 bg-white" aria-labelledby="hodnoty-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12" data-fade-up>
        <h2 id="hodnoty-heading" class="text-3xl font-black text-[#2D2D2D] md:text-4xl">Proč Sluníčko?</h2>
        <p class="mt-3 text-gray-500 max-w-2xl mx-auto">Rodinná atmosféra, individuální přístup a programy, které děti skutečně baví.</p>
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" data-stagger>
        {[
          { icon: "ph:paint-brush-duotone", iconColor: "text-[#D4A017]", title: "Tvořivost a umění", desc: "Malování, keramika, dramatika a hudba jsou každodenní součástí programu.", bg: "bg-[#FFF9C4]", ring: "ring-[#FFD600]/40" },
          { icon: "ph:medal-duotone", iconColor: "text-[#AD1457]", title: "Bruslení a sport", desc: "Trénink bruslení na stadionu Sareza, atletika, jóga a pohybové aktivity.", bg: "bg-[#FCE4EC]", ring: "ring-[#F48FB1]/40" },
          { icon: "ph:music-notes-duotone", iconColor: "text-[#1565C0]", title: "Muzikoterapie", desc: "Cajony, bubny a tibetské mísy jako součást každodenního rytmu školky.", bg: "bg-[#E3F2FD]", ring: "ring-[#90CAF9]/40" },
          { icon: "ph:dog-duotone", iconColor: "text-[#2E7D32]", title: "Canisterapie", desc: "Práce s terapeutickým psem pro rozvoj empatie a emocionálního inteligence.", bg: "bg-[#E8F5E9]", ring: "ring-[#A5D6A7]/40" },
          { icon: "ph:users-three-duotone", iconColor: "text-[#6A1B9A]", title: "Partnerství s rodiči", desc: "Snídaně s rodiči, tvořivé dílny a společné besídky po celý rok.", bg: "bg-[#EDE7F6]", ring: "ring-[#CE93D8]/40" },
          { icon: "ph:book-open-duotone", iconColor: "text-[#E65100]", title: "Projekt Přečti", desc: "Dobrovolnické babičky čtou dětem pohádky — mezigenerační spolupráce.", bg: "bg-[#FFF3E0]", ring: "ring-[#FFCC80]/40" },
        ].map(({ icon, iconColor, title, desc, bg, ring }) => (
          <div class:list={["rounded-xl p-6 ring-1 hover:ring-[#F9C22E] transition", bg, ring]}>
            <Icon name={icon} class:list={["h-9 w-9 mb-3", iconColor]} aria-hidden="true" />
            <h3 class="font-bold text-lg text-[#2D2D2D] mb-2">{title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Denní program + Ceník preview -->
  <section class="py-16 bg-[#F0FFF4]" aria-labelledby="program-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div data-fade-up>
          <h2 id="program-heading" class="text-3xl font-black text-[#2D2D2D] md:text-4xl mb-4">Náš den v školce</h2>
          <p class="text-gray-600 mb-6 leading-relaxed">
            Každý den je naplněn smysluplnými aktivitami — od ranního hraní přes řízenou pedagogickou činnost až po odpolední volné aktivity.
          </p>
          <div class="space-y-3">
            {[
              { time: "6:30–8:30", activity: "Příchod dětí, ranní volná hra", bg: "bg-[#FFF9C4]" },
              { time: "8:00–9:20", activity: "Didaktické aktivity, hygiena, svačina", bg: "bg-[#FCE4EC]" },
              { time: "9:20–10:20", activity: "Řízená pedagogická činnost, pohybová aktivita", bg: "bg-[#E3F2FD]" },
              { time: "10:20–11:30", activity: "Příprava na pobyt venku, vycházka", bg: "bg-[#E8F5E9]" },
              { time: "11:30–14:00", activity: "Oběd, hygiena, odpočinek", bg: "bg-[#EDE7F6]" },
              { time: "14:00–17:00", activity: "Svačina, odpolední aktivity, volná hra", bg: "bg-[#FFF3E0]" },
            ].map(({ time, activity, bg }) => (
              <div class="flex gap-4 items-start">
                <span class:list={["shrink-0 rounded-lg px-3 py-1 text-xs font-bold text-[#2D2D2D]", bg]}>{time}</span>
                <span class="text-sm text-gray-700 pt-1">{activity}</span>
              </div>
            ))}
          </div>
          <a href="/nas-den" class="mt-6 inline-flex items-center gap-2 font-bold text-[#D4A017] hover:underline">
            Celý denní program
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
        <div class="rounded-xl bg-[#F0F7FF] p-8 shadow-sm ring-1 ring-[#90CAF9]/40" data-fade-up>
          <h3 class="font-black text-xl text-[#2D2D2D] mb-6">Přehled ceníku</h3>
          <div class="space-y-4">
            {[
              { label: "Celý den (6:30–17:00)", price: "od 3 500 Kč/měs", note: "děti 3+ let, pravidelná docházka" },
              { label: "Půl den (6:30–12:00)", price: "od 3 950 Kč/měs", note: "děti 3+ let" },
              { label: "Nepravidelná docházka", price: "od 2 750 Kč", note: "5 dní v měsíci" },
              { label: "Strava celý den", price: "75 Kč/den", note: "2× svačina + oběd + pitný režim" },
            ].map(({ label, price, note }) => (
              <div class="flex justify-between items-start gap-4 pb-4 border-b border-gray-100 last:border-0 last:pb-0">
                <div>
                  <div class="font-semibold text-sm text-[#2D2D2D]">{label}</div>
                  <div class="text-xs text-gray-500">{note}</div>
                </div>
                <div class="font-bold text-[#D4A017] shrink-0 text-sm">{price}</div>
              </div>
            ))}
          </div>
          <a href="/cenik" class="mt-6 w-full inline-flex items-center justify-center rounded-lg bg-[#F9C22E] px-5 py-2.5 font-bold text-sm text-[#2D2D2D] transition hover:bg-[#D4A017]">
            Kompletní ceník
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Tým -->
  <section class="py-16 bg-white" aria-labelledby="tym-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12" data-fade-up>
        <h2 id="tym-heading" class="text-3xl font-black text-[#2D2D2D] md:text-4xl">Náš tým</h2>
        <p class="mt-3 text-gray-500">Zkušené pedagožky, které milují svoji práci.</p>
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
        {[
          { name: "Michaela Krečmerová, DiS.", role: "Ředitelka", icon: "ph:briefcase-duotone", iconColor: "text-[#D4A017]", desc: "Předškolní pedagogika, cestování, astronomie.", bg: "bg-[#FFF9C4]", ring: "ring-[#FFD600]/40" },
          { name: "Bc. Lucie Sližová, DiS.", role: "Učitelka", icon: "ph:chalkboard-teacher-duotone", iconColor: "text-[#AD1457]", desc: "Dějiny umění, zkušenosti se speciálními potřebami.", bg: "bg-[#FCE4EC]", ring: "ring-[#F48FB1]/40" },
          { name: "Veronika Vlčková", role: "Učitelka", icon: "ph:palette-duotone", iconColor: "text-[#1565C0]", desc: "Zkušenosti z USA, studuje předškolní pedagogiku.", bg: "bg-[#E3F2FD]", ring: "ring-[#90CAF9]/40" },
          { name: "Petra Konečná", role: "Provoz & kuchyně", icon: "ph:cooking-pot-duotone", iconColor: "text-[#2E7D32]", desc: "Rodinné studie, zahrádkaření a cestování.", bg: "bg-[#E8F5E9]", ring: "ring-[#A5D6A7]/40" },
        ].map(({ name, role, icon, iconColor, desc, bg, ring }) => (
          <div class:list={["rounded-xl p-6 text-center ring-1", bg, ring]}>
            <Icon name={icon} class:list={["h-9 w-9 mb-3 mx-auto", iconColor]} aria-hidden="true" />
            <h3 class="font-bold text-[#2D2D2D]">{name}</h3>
            <p class="text-sm font-semibold text-[#D4A017] mt-1 mb-3">{role}</p>
            <p class="text-xs text-gray-500 leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/o-skolce" class="inline-flex items-center gap-2 font-bold text-[#D4A017] hover:underline">
          Více o školce a týmu
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-[#2D2D2D]" aria-labelledby="cta-heading">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <Logo width={52} height={55} class="mb-4 mx-auto" />
      <h2 id="cta-heading" class="text-3xl font-black text-white md:text-4xl">Přijďte se podívat</h2>
      <p class="mt-4 text-gray-400 leading-relaxed max-w-xl mx-auto">
        Rádi vám ukážeme školku osobně. Zavolejte nám nebo napište e-mail a domluvíme termín prohlídky.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="tel:+420725828130" class="inline-flex items-center gap-2 rounded-lg bg-[#F9C22E] px-7 py-3.5 font-bold text-[#2D2D2D] transition hover:bg-[#D4A017]">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          725 828 130
        </a>
        <a href="/registrace" class="inline-flex items-center gap-2 rounded-lg border-2 border-white px-7 py-3.5 font-bold text-white transition hover:bg-white hover:text-[#2D2D2D]">
          Chci zapsat dítě
        </a>
      </div>
      <p class="mt-6 text-sm text-gray-500">Bohuslava Martinů 812/11, Ostrava-Poruba · Po–Pá 6:30–17:00</p>
    </div>
  </section>

</BaseLayout>
