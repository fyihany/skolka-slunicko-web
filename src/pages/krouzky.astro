---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from 'astro-icon/components';
import PageHero from "../components/PageHero.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Domů", "item": "https://www.skolka-slunicko.cz" },
      { "@type": "ListItem", "position": 2, "name": "Kroužky", "item": "https://www.skolka-slunicko.cz/krouzky" }
    ]
  }
];

const otherActivities = [
  {
    icon: "ph:music-notes-duotone",
    iconColor: "text-[#AD1457]",
    title: "Muzikoterapie",
    desc: "Práce s cajony, bubny a tibetskými mísami. Zvuk a rytmus jako prostředek klidu, soustředění a tvořivosti.",
    bg: "bg-[#FCE4EC]", ring: "ring-[#F48FB1]/40",
  },
  {
    icon: "ph:dog-duotone",
    iconColor: "text-[#1565C0]",
    title: "Canisterapie",
    desc: "Pravidelná setkání s terapeutickým psem pro rozvoj empatie, zodpovědnosti a emocionálního prožívání.",
    bg: "bg-[#E3F2FD]", ring: "ring-[#90CAF9]/40",
  },
  {
    icon: "ph:person-simple-run-duotone",
    iconColor: "text-[#2E7D32]",
    title: "Atletika",
    desc: "Pohybové aktivity zaměřené na koordinaci, vytrvalost a radost z pohybu. Probíhají v rámci každodenního programu.",
    bg: "bg-[#E8F5E9]", ring: "ring-[#A5D6A7]/40",
  },
  {
    icon: "ph:book-open-duotone",
    iconColor: "text-[#6A1B9A]",
    title: "Projekt Přečti",
    desc: "Dobrovolnické babičky přicházejí číst dětem pohádky. Krásný příklad mezigenerační spolupráce a lásky ke čtení.",
    bg: "bg-[#EDE7F6]", ring: "ring-[#CE93D8]/40",
  },
  {
    icon: "ph:mask-happy-duotone",
    iconColor: "text-[#E65100]",
    title: "Anglické divadlo",
    desc: "Divadelní představení v anglickém jazyce. Zábavný a přirozený úvod do světového jazyka formou příběhů a her.",
    bg: "bg-[#FFF3E0]", ring: "ring-[#FFCC80]/40",
  },
  {
    icon: "ph:globe-duotone",
    iconColor: "text-[#D4A017]",
    title: "Výlet do planetária",
    desc: "Výpravy do ostravského planetária. Děti objevují tajemství vesmíru, přírody a světa kolem nás.",
    bg: "bg-[#FFF9C4]", ring: "ring-[#FFD600]/40",
  },
];
---

<BaseLayout
  title="Kroužky a aktivity | Mateřská škola Sluníčko Ostrava-Poruba"
  description="Bruslení, muzikoterapie, canisterapie, atletika a další aktivity v MŠ Sluníčko Ostrava-Poruba. Speciální programy pro děti od 2 let."
  schema={schema}
  canonical="https://www.skolka-slunicko.cz/krouzky"
>

  <!-- Breadcrumb -->
  <nav aria-label="Drobečková navigace" class="bg-white border-b border-gray-100">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center gap-2 text-sm text-gray-500">
        <li><a href="/" class="hover:text-[#D4A017] transition">Domů</a></li>
        <li aria-hidden="true" class="text-gray-300">/</li>
        <li class="font-semibold text-[#2D2D2D]" aria-current="page">Kroužky a aktivity</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <PageHero labelId="krouzky-heading" icon="ph:star-duotone">
    <h1 id="krouzky-heading" class="text-4xl font-black text-[#2D2D2D] sm:text-5xl leading-tight">
      Kroužky a aktivity
    </h1>
    <p class="mt-4 text-lg text-gray-600 leading-relaxed">
      Speciální programy, které obohacují každý den v naší školce.
    </p>
  </PageHero>

  <!-- Bruslení — featured -->
  <section class="py-16 bg-white" aria-labelledby="brusleni-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-xl bg-[#E3F2FD] p-8 md:p-12 ring-2 ring-[#90CAF9]/40" data-fade-up>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
          <div>
            <div class="inline-flex items-center rounded-lg bg-[#F9C22E]/30 px-4 py-1 text-sm font-semibold text-[#D4A017] mb-4">
              Vlajkový program
            </div>
            <h2 id="brusleni-heading" class="text-3xl font-black text-[#2D2D2D] md:text-4xl mb-4">
              Trénink bruslení
            </h2>
            <p class="text-gray-600 leading-relaxed mb-6">
              Trénink na ledové ploše stadionu Sareza pod vedením zkušených trenérů. Jeden z unikátních programů, který naše školka nabízí jako součást běžného dopoledního programu.
            </p>
            <dl class="space-y-3">
              {[
                { label: "Kdy", value: "září–červen, dopolední hodiny v rámci programu školky" },
                { label: "Pro koho", value: "Děti od 4 let" },
                { label: "Vybavení", value: "Brusle a přilby jsou zapůjčeny zdarma" },
              ].map(({ label, value }) => (
                <div class="flex gap-2">
                  <dt class="font-bold text-sm text-[#D4A017] shrink-0 w-24">{label}:</dt>
                  <dd class="text-sm text-gray-700">{value}</dd>
                </div>
              ))}
            </dl>
          </div>
          <div class="flex justify-center">
            <div class="text-center">
              <Icon name="ph:medal-duotone" class="h-24 w-24 text-[#1565C0] mb-4 mx-auto" aria-hidden="true" />
              <p class="text-sm font-semibold text-gray-500">Stadion Sareza, Ostrava-Poruba</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Ostatní aktivity -->
  <section class="py-16 bg-[#FFF0F5]" aria-labelledby="ostatni-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12" data-fade-up>
        <h2 id="ostatni-heading" class="text-3xl font-black text-[#2D2D2D] md:text-4xl">Další aktivity</h2>
        <p class="mt-3 text-gray-500 max-w-2xl mx-auto">
          Pestrá nabídka aktivit, které doplňují každodenní program školky.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" data-stagger>
        {otherActivities.map(({ icon, iconColor, title, desc, bg, ring }) => (
          <div class:list={["rounded-xl p-6 ring-1 hover:ring-[#F9C22E] transition", bg, ring]}>
            <Icon name={icon} class:list={["h-9 w-9 mb-3", iconColor]} aria-hidden="true" />
            <h3 class="font-bold text-lg text-[#2D2D2D] mb-2">{title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-[#2D2D2D]" aria-labelledby="krouzky-cta-heading">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 id="krouzky-cta-heading" class="text-3xl font-black text-white md:text-4xl">
        Máte dotaz k aktivitám?
      </h2>
      <p class="mt-4 text-gray-400 leading-relaxed">
        Rádi vám zodpovíme vše osobně nebo telefonicky.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="tel:+420725828130" class="inline-flex items-center gap-2 rounded-lg bg-[#F9C22E] px-7 py-3.5 font-bold text-[#2D2D2D] transition hover:bg-[#D4A017]">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Zavolejte: 725 828 130
        </a>
        <a href="/kontakt" class="inline-flex items-center gap-2 rounded-lg border-2 border-white px-7 py-3.5 font-bold text-white transition hover:bg-white hover:text-[#2D2D2D]">
          Napište nám
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
