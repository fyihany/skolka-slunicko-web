---
interface Props {
  class?: string;
  width?: number;
  height?: number;
}
const { class: className = "", width = 44, height = 47 } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  xmlns:xlink="http://www.w3.org/1999/xlink"
  width={width}
  height={height}
  viewBox="0 0 302 320"
  role="img"
  aria-label="Logo Sluníčko"
  class={className}
>
  <defs>
    <radialGradient id="sunGrad" cx="42%" cy="32%" r="72%">
      <stop offset="0%" stop-color="#fff8a8"/>
      <stop offset="52%" stop-color="#f6ea32"/>
      <stop offset="100%" stop-color="#e0cf1c"/>
    </radialGradient>
  </defs>

  <!-- SLUNÍČKO text -->
  <g fill="#202124" font-family='"Chalkboard SE","Comic Sans MS","Nunito",system-ui,sans-serif' font-weight="700" font-size="32">
    <text x="68"  y="99"  transform="rotate(-27 68 99)">S</text>
    <text x="93"  y="80"  transform="rotate(-18 93 80)">L</text>
    <text x="121" y="69"  transform="rotate(-8 121 69)">U</text>
    <text x="148" y="66"  transform="rotate(2 148 66)">N</text>
    <text x="176" y="70"  transform="rotate(12 176 70)">Í</text>
    <text x="202" y="83"  transform="rotate(23 202 83)">Č</text>
    <text x="224" y="102" transform="rotate(35 224 102)">K</text>
    <text x="241" y="126" transform="rotate(47 241 126)">O</text>
