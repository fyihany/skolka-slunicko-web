---
import { Icon } from 'astro-icon/components';

interface Props {
  labelId: string;
  icon: string;
  bg?: string;
  maxWidth?: string;
}

const {
  labelId,
  icon,
  bg = "bg-[#FFFBF0]",
  maxWidth = "max-w-2xl",
} = Astro.props;
---

<section class={`${bg} py-16 md:py-20`} aria-labelledby={labelId}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between gap-8">
      <div class={maxWidth}>
        <slot />
      </div>
      <div class="hidden lg:flex shrink-0 items-center justify-center" aria-hidden="true">
        <Icon name={icon} class="h-56 w-56 text-[#F9C22E]/25" />
      </div>
    </div>
  </div>
</section>
