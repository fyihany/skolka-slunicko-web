---
import Logo from "./Logo.astro";
const year = new Date().getFullYear();

const footerLinks = [
  { href: "/o-skolce", label: "O školce" },
  { href: "/nas-den", label: "Náš den" },
  { href: "/krouzky", label: "Kroužky" },
  { href: "/cenik", label: "Ceník" },
  { href: "/registrace", label: "Registrace" },
  { href: "/jidelnicek", label: "Jídelníček" },
  { href: "/galerie", label: "Galerie" },
  { href: "/aktuality", label: "Aktuality" },
  { href: "/ke-stazeni", label: "Ke stažení" },
  { href: "/co-dite-potrebuje", label: "Co dítě potřebuje" },
  { href: "/dulezite", label: "Důležité info" },
  { href: "/projekty", label: "Projekty" },
];
---

<footer class="bg-[#2D2D2D] text-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-4" aria-label="Mateřská škola Sluníčko">
          <Logo width={52} height={55} class="h-13 w-auto" />
          <div>
            <div class="font-bold text-lg text-white">MŠ Sluníčko</div>
            <div class="text-xs text-gray-400">Soukromá mateřská škola</div>
          </div>
        </a>
        <p class="text-sm text-gray-400 leading-relaxed">
          Školka rodinného typu v Ostravě-Porubě. Péče, láska a kreativita pro vaše dítě.
        </p>
        <!-- Social -->
        <div class="mt-4 flex gap-3">
          <a
            href="https://www.facebook.com/materskaskolkaslunicko"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook MŠ Sluníčko (otevře nové okno)"
            class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 text-white transition hover:bg-[#F9C22E] hover:text-[#2D2D2D]"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
            </svg>
          </a>
          <a
            href="https://www.instagram.com/materska_skola_slunicko"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram MŠ Sluníčko (otevře nové okno)"
            class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 text-white transition hover:bg-[#F9C22E] hover:text-[#2D2D2D]"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div class="lg:col-span-2">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-400 mb-4">Navigace</h2>
        <ul class="grid grid-cols-2 gap-2">
          {footerLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-gray-300 hover:text-[#F9C22E] transition">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-400 mb-4">Kontakt</h2>
        <address class="not-italic space-y-3 text-sm text-gray-300">
          <p class="flex gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#F9C22E]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span>Bohuslava Martinů 812/11<br/>Ostrava-Poruba, 708 00</span>
          </p>
          <p class="flex gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#F9C22E]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href="tel:+420725828130" class="hover:text-[#F9C22E] transition">725 828 130</a>
          </p>
          <p class="flex gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#F9C22E]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:info@skolka-slunicko.cz" class="hover:text-[#F9C22E] transition">info@skolka-slunicko.cz</a>
          </p>
          <p class="flex gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#F9C22E]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span>Po–Pá: 6:30–17:00</span>
          </p>
        </address>
      </div>
    </div>

    <div class="mt-10 border-t border-white/10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-gray-500">
      <p>© {year} Soukromá mateřská škola Sluníčko — REDUZA pro s.r.o.</p>
      <nav aria-label="Doplňkové odkazy">
        <a href="/dulezite" class="hover:text-[#F9C22E] transition">Důležité informace</a>
      </nav>
    </div>
  </div>
</footer>
